# Discord Webhook URL (Required)
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE"

# Optional string to ping a Discord Role or User when a chapter drops.
# To tag @everyone, use: "@everyone"
# To tag a role, use its ID like: "<@&123456789012345678>"
# To tag a specific user, use their ID like: "<@123456789012345678>"
DISCORD_MENTION=""
